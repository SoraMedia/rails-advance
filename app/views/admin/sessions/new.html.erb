<h1>管理ログイン</h1>

<% if flash[:alert] %>
  <p style="color:red"><%= flash[:alert] %></p>
<% end %>

<%= form_with url: admin_session_path, method: :post do %>
  <div>
    <label>メール</label>
    <%= email_field_tag :email %>
  </div>

  <div>
    <label>パスワード</label>
    <%= password_field_tag :password %>
  </div>

  <%= submit_tag "ログイン" %>
<% end %>
